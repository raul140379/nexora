+    @ReactMethod
+    public void writeHex(String hexString, final Promise promise) {
+        try {
+            String[] parts = hexString.trim().split("\\s+");
+            byte[] data = new byte[parts.length];
+            for (int i = 0; i < parts.length; i++) {
+                data[i] = (byte) Integer.parseInt(parts[i].trim(), 16);
+            }
+            if (sendDataByte(data)) {
+                promise.resolve(null);
+            } else {
+                promise.reject("COMMAND_NOT_SEND");
+            }
+        } catch (Exception e) {
